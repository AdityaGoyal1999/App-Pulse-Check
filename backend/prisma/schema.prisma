// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CheckStatus {
  NEW
  UP
  DOWN
}

enum Plan {
  FREE
  SUPPORTER
  ENTERPRISE
  ENTERPRISE_PLUS
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  passwordHash         String
  alertWebhookUrl      String? // Slack incoming webhook URL
  alertEmail           String? // destination email (Resend)
  plan                 Plan     @default(FREE)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  createdAt            DateTime @default(now())
  checks               Check[]
}

model Check {
  id              String      @id @default(cuid())
  uuid            String      @unique @default(uuid())
  userId          String
  name            String
  intervalSeconds Int
  graceSeconds    Int
  status          CheckStatus @default(NEW)
  lastPingedAt    DateTime?
  paused            Boolean     @default(false)
  alertSent         Boolean     @default(false)
  alertWebhookUrl         String? // Slack incoming webhook URL
  alertDiscordWebhookUrl  String? // Discord incoming webhook URL
  alertEmail              String? // destination email (Resend)
  createdAt         DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id])
  pingLogs        PingLog[]

  @@index([userId])
}

model PingLog {
  id       String   @id @default(cuid())
  checkId  String
  pingedAt DateTime @default(now())
  check    Check    @relation(fields: [checkId], references: [id])

  @@index([checkId])
}
