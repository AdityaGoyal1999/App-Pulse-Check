# Copy to .env and .env.local, then fill in real values.
# .env — shared local defaults (DATABASE_URL, PORT)
# .env.local — secrets (JWT_SECRET); not committed

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pulsecheck?schema=public"
PORT=3000

JWT_SECRET="generate-with-openssl-rand-base64-32"
JWT_EXPIRES_IN="7d"

# Alerting (Day 5) — email via Resend; Slack webhook is per-user in DB
RESEND_API_KEY="re_xxxxxxxx"
# Sender for alert emails (must match the Resend account / verified sender)
RESEND_FROM_EMAIL="AppPulseCheck <email@example.com>"
APP_URL="http://localhost:3001"
APP_NAME="AppPulseCheck"
